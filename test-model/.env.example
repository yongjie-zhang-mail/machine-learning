
# DeepSeek API Key (for DeepSeek model)
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# Qwen endpoint url
QWEN_ENDPOINT=your_qwen_endpoint_here
# Qwen API Key
QWEN_API_KEY=your_qwen_api_key_here
# Test image URL (for testing Qwen model with image input)
TEST_IMG_URL=your_test_image_url_here

# LangSmith (optional - for tracing and monitoring)
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=text2sql-deepagent

# Tavily API (optional - for web search capabilities)
TAVILY_API_KEY=your_tavily_api_key_here
